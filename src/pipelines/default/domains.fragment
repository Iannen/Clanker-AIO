			        => <either -> harness-development/>
			        => <or -> instruction-development/>
		</purpose>
                <first-class-citizens/>
                    => '<game-runtime>'
                        => <most-important: ['<language>', '<knowledge>','<knowledge-analysis>']/>
                        => <just-examples: ['<codebase>', '<backlog>','<repository-history>']/>
                <important-concepts/>
                    => <prompt-engineering: prompt contruction for llms/>
                    => <token-economy: reducing token usage/>
                    => <academic-grounding: science backed practices/>
                <reply-schemas>
                    <tag-artifact-nocontent>
                        <usecases/>
                            => <show user tag related information for purposes of discussion, where content not required/>
                            => <satisfy explicit user requests for tag structures>
                                <tags-to-display-ambiguous -> show full tag structure of '<game-runtime>'>
                        <reply-components>
                            = > <first-component: modify below template to user requirements >
'''markdown
<root>
    <enclosed-content-is-hidden: all content between tags is hidden>
    </child>
</root>
'''
                            = > </first-component>
                            = > <second-component: comments regarding artifact/>
                    /<tag-artifact-nocontent>
                    <domain-fallthrough>
                        <usecases: no other domain reply-schemas apply properly/>
                        <only-component: appropriate conversational reply>
                    </domain-fallthrough>
                </reply-schemas>
            </instruction-meta-development>
            <codebase>
                <codebase-doctrine>
                    <info: ideals, mandates and prohibitions are file scoped/>
                    <file-ideal: few empty lines/>
                    <exceptions: at discretion>
                        <example: .json prohibits comments/>
                    </exceptions>
                    <divisions: primary, utils>
                        <shared-code-ideals>
                            <code-as-doc: code should be self-explanatory/>
                        </shared-code-ideals>
                        <shared-comment-ideals: applies to all files of codebase>
                            <language-appropriateness: comments displayed should be language appropriate./> 
                            <DRY: the code carries the meaning - comments provide additional context>
                            <comments-inside-methods: forbidden/>
                        </shared-comment-ideals>
                        <primary-bucket>
                            <wants-to: migrate low level code to utils/>
                            <deps: utils, common-imports/>
                            <code-ideals: express role as primary code> 
                                <style: expressive, rich/>
                            </code-ideals>
                            <comment-ideals: illucidate application workings>
                                <mandates: required comments>
                                    <file-intro: one line to describe file purpose/>
                                    <bottom-level-members: one docstyle type comment per bottom level member/>
                                    <construct-declarations: one docstyle comment/>
                                    <interface-type-construct-members: full docstyle/>
                                    <other-construct-members: as appropriate/>
                                </mandates>
                            </comment-ideals>
                        </primary-bucket>
                        <utils-bucket>
                            <dependency-prohibition: never 'primary-bucket'/>
                            <depends-on: as required/>
                            <code-ideals>
                                <desired-attribute: highly testable/>
                            </code-ideals>
                            <comment-ideals/>
                        </utils-bucket>
                        <separation-strategy: language appropriate>
                            <golang-code-separation-strategy: dependency inversion by interface/>
                            <rest: as appropriate/>
                        </separation-strategy>
                    </divisions>
                </codebase-doctrine>
                <codebase-content>
                    <file-tree>
			§§file_tree§§
                    </file-tree>
                    <files>
			§§files§§
                    </files>
                </codebase-content>
            </codebase>
