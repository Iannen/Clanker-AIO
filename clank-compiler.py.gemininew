#!/usr/bin/env python3
""" Clanker AIO Repository Manager """
""" **Last edit notes (1 line format):** Upgraded EnvironmentManager to robust multi-file structural artifact pipeline with atomic states."""
import os
import shutil
import glob
import sys
import json
import base64
import re
import readline
import hashlib
import time
from dataclasses import dataclass, field
from pathlib import Path

STRIP_MARKER = "--- START PROMPT ---"

@dataclass
class AppState:
    script_dir: Path = field(default_factory=lambda: Path(__file__).resolve().parent)
    repo_root: Path = field(default_factory=Path.cwd)
    sets: list = field(default_factory=list)
    flow_char: str = "q"
    debug: bool = False
    beancounter: int = 0
    last_message: str = "Ready playa 2"
    disk_config: dict = field(default_factory=dict)

class Harness:
    def __init__(self, state_service: AppState):
        self.state = state_service
        
    def get_char(self):
        import tty
        import termios
        fd = sys.stdin.fileno()
        old_settings = termios.tcgetattr(fd)
        try:
            tty.setraw(sys.stdin.fileno())
            ch = sys.stdin.read(1)
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
        return ch

    def load_config_from_disk(self):
        repo_config = self.state.repo_root / "Clanker/config.clank"
        if repo_config.exists():
            try:
                data = json.loads(repo_config.read_text(encoding="utf-8"))
                self.state.disk_config = data
                self.state.sets = data.get("rag_sets", [])
            except Exception:
                self.state.disk_config = {"active_rag_set": "", "rag_sets": [], "active_mutation_path": ""}
                self.state.sets = []
        else:
            self.state.disk_config = {"active_rag_set": "", "rag_sets": [], "active_mutation_path": ""}
            self.state.sets = []

    def start(self):
        repo_config_dir = self.state.repo_root / "Clanker"
        repo_config_file = repo_config_dir / "config.clank"
        if not repo_config_file.exists():
            try:
                ans = input("This isn't a repository. Initialize? (y/n): ").strip().lower()
                if ans == 'y':
                    repo_config_dir.mkdir(parents=True, exist_ok=True)
                    default_config = {
                        "active_rag_set": "script",
                        "rag_sets": [
                            {
                                "name": "script",
                                "paths": ["clank-compiler.py", "src/**/*.fragment"]
                            },
                            {
                                "name": "documentation",
                                "paths": ["docs/**/*.md", "README.md"]
                            }
                        ],
                        "active_mutation_path": ""
                    }
                    repo_config_file.write_text(json.dumps(default_config, indent=4), encoding="utf-8")
                    self.load_config_from_disk()
                else:
                    self.exit()
            except (KeyboardInterrupt, EOFError):
                self.exit()
        else:
            self.load_config_from_disk()
        while True:
            self.load_config_from_disk()
            self.render()
            try:
                key = self.get_char().lower()
            except (KeyboardInterrupt, EOFError):
                self.exit()
            if key == "\x03":
                self.exit()
            if key in ("q", "w", "e", "r", "a", "s", "d", "f"):
                self.handle(key)

    def handle(self, command):
        self.state.beancounter += 1
        if command in ("q", "w", "e"):
            self.state.flow_char = command
            self.state.debug = False
            try:
                compiled = Compiler.compile(self.state)
                lines_count = EnvironmentManager.copy_to_clipboard(compiled)
                self.state.last_message = f"{command.upper()} => {lines_count} lines copied to clipboard."
            except Exception as e:
                self.state.last_message = f"❌ Compilation Error: {e}"
        elif command == "r":
            self.state.flow_char = "r"
            self.state.debug = True
            try:
                compiled = Compiler.compile(self.state)
                lines_count = EnvironmentManager.copy_to_clipboard(compiled)
                self.state.last_message = f"R (Debug) => {lines_count} lines copied to clipboard with tracking headers."
            except Exception as e:
                self.state.last_message = f"❌ Compilation Error: {e}"
        elif command == "f":
            self.state.beancounter -= 1
            EnvironmentManager.acquire_and_run(self.state, self.get_char)
        elif command in ("a", "s", "d"):
            self.state.last_message = f"Log: Handler executed for action '{command}' (not implemented yet at least)."

    def render(self):
        os.system("clear" if os.name != "nt" else "cls")
        st = self.state
        location_path = st.repo_root / "Clanker"
        location_marker = f"{st.repo_root} [Active]" if location_path.exists() else str(st.repo_root)
        active_set = st.disk_config.get("active_rag_set", "None")
        print("================================================")
        print("⚡ Interactive Launcher - Clanker Consultant")
        print("================================================")
        print(f"Location:    {location_marker}")
        print(f"Repository:  {st.repo_root}")
        print(f"Active RAG:  {active_set}")
        print(f"Commands:    {st.beancounter}")
        print(f"Message:     <{st.last_message}>")
        print("================================================")
        print("")
        print("   |Q|   |W|   |E|   |R|")
        print("   |A|   |S|   |D|   |F|")
        print("")
        print("   |q|   Codebase (Standard Mode)")
        print("   |w|   Documentation")
        print("   |e|   Config")
        print("   |r|   Clank Dev (Debug)")
        print("   |f|   File Manager (Sub-Loop)")
        print("================================================")
        print("   [Ctrl+C] Exit")
        print("================================================")
        print("> ", end="", flush=True)

    def exit(self):
        print("\n\n👋 Bye bye!")
        sys.exit(0)

class Compiler:
    @staticmethod
    def _resolve_rag_files(state: AppState) -> list:
        active_set_name = state.disk_config.get("active_rag_set", "")
        rag_sets = state.disk_config.get("rag_sets", [])
        if not rag_sets:
            raise ValueError("Configuration Error: No 'rag_sets' defined in config.clank.")
        target_set = None
        for r_set in rag_sets:
            if r_set.get("name") == active_set_name:
                target_set = r_set
                break
        if not target_set:
            raise ValueError(f"Configuration Error: Active RAG set '{active_set_name}' not found in available rag_sets.")
        resolved_paths = []
        for pattern in target_set.get("paths", []):
            full_pattern = str(state.repo_root / pattern)
            for p in glob.glob(full_pattern, recursive=True):
                path_obj = Path(p)
                if path_obj.is_file():
                    resolved_paths.append(path_obj)
        return sorted(list(set(resolved_paths)))

    @staticmethod
    def generate_file_tree(state: AppState) -> str:
        files = Compiler._resolve_rag_files(state)
        if not files:
            return "."
        tree_lines = ["."]
        paths_relative = [f.relative_to(state.repo_root) for f in files]
        for path in paths_relative:
            parts = path.parts
            for i in range(len(parts)):
                current_depth = i
                is_last_item = (i == len(parts) - 1)
                prefix = "    " * current_depth + "└── " if is_last_item else "    " * current_depth + "├── "
                line = f"{prefix}{parts[i]}"
                if line not in tree_lines:
                    tree_lines.append(line)
        return "\n".join(tree_lines)

    @staticmethod
    def generate_files_content(state: AppState) -> str:
        files = Compiler._resolve_rag_files(state)
        output_blocks = []
        for file_path in files:
            try:
                rel_path = file_path.relative_to(state.repo_root)
                content = file_path.read_text(encoding="utf-8")
                block = f"        <file>\n            <path>{rel_path}</path>\n            <document>\n{content}\n            </document>\n        </file>"
                output_blocks.append(block)
            except Exception as e:
                output_blocks.append(f"        <file>\n            <path>{file_path}</path>\n            <error>{e}</error>\n        </file>")
        return "\n".join(output_blocks)

    @staticmethod
    def resolve_source(token, state: AppState):
        file_name = f"{token}.fragment"
        flow_path = state.script_dir / "src" / "pipelines" / "flows" / state.flow_char / file_name
        if flow_path.exists():
            return flow_path, flow_path.read_text(encoding="utf-8")
        default_path = state.script_dir / "src" / "pipelines" / "default" / file_name
        if default_path.exists():
            return default_path, default_path.read_text(encoding="utf-8")
        mem_content = DefaultPrompt.get_default(token)
        if mem_content is not None:
            dummy_path = Path(f"src/pipelines/default/{token}.fragment")
            return dummy_path, mem_content
        raise FileNotFoundError(f"Could not resolve fragment '{token}' in flow directory '{state.flow_char}', fallback 'default', or compiler defaults.")

    @staticmethod
    def compile(state: AppState):
        return Compiler.resolve_node("game-runtime", [], state)

    @staticmethod
    def resolve_node(token, stack, state: AppState):
        if token in stack:
            raise RuntimeError("Include cycle detected: " + " -> ".join(stack + [token]))
        if token == "file_tree":
            return Compiler.generate_file_tree(state)
        elif token == "files":
            return Compiler.generate_files_content(state)
        source_path, raw_content = Compiler.resolve_source(token, state)
        content = Compiler.preprocess(raw_content, source_path, state)
        lines = content.splitlines()
        processed_lines = []
        for line in lines:
            match = re.match(r"^\s*§§(.*)§§\s*$", line)
            if match:
                token_id = match.group(1)
                line = Compiler.resolve_node(token_id, stack + [token], state)
            processed_lines.append(line)
        return "\n".join(processed_lines)

    @staticmethod
    def preprocess(content, path, state: AppState):
        if state.debug:
            return f"== {path} ==\n" + content
        else:
            lines = content.splitlines()
            marker_index = -1
            for idx, line in enumerate(lines):
                if line.strip() == STRIP_MARKER:
                    marker_index = idx
                    break
            if marker_index != -1:
                return "\n".join(lines[marker_index + 1:])
            return content

class EnvironmentManager:
    def __init__(self, state_service: AppState):
        self.state = state_service
        self.backup_dir = self.state.repo_root / "Clanker/backups"
        self.artifact_path = self.backup_dir / "refactor-plan.artifact"
        self.hash_map_path = self.backup_dir / "hashes.map"
        self.past_dir = self.state.repo_root / "Clanker/past_artifacts"

    @staticmethod
    def _str_sha256(text: str) -> str:
        return hashlib.sha256(text.encode("utf-8")).hexdigest()

    @staticmethod
    def _file_sha256(path: Path) -> str:
        if not path.is_file():
            return ""
        hash_sha256 = hashlib.sha256()
        with open(path, "rb") as f:
            for chunk in iter(lambda: f.read(4096), b""):
                hash_sha256.update(chunk)
        return hash_sha256.hexdigest()

    def _parse_artifact(self, content: str) -> dict:
        plan = {"create": [], "delete": []}
        create_matches = re.findall(r"§#§start:create:(.*?)§#§\n(.*?)\n§#§end:create:\1§#§", content, re.DOTALL)
        for path, body in create_matches:
            plan["create"].append({"path": path.strip(), "content": body})
        delete_matches = re.findall(r"§#§start:delete:(.*?)§#§\n(.*?)\n§#§end:delete:\1§#§", content, re.DOTALL)
        for path, body in delete_matches:
            plan["delete"].append({"path": path.strip()})
        return plan

    def _get_state(self) -> str:
        if not self.backup_dir.exists():
            return "free"
        if not self.artifact_path.exists() or not self.hash_map_path.exists():
            return "error"
        try:
            artifact_content = self.artifact_path.read_text(encoding="utf-8")
            hmap = json.loads(self.hash_map_path.read_text(encoding="utf-8"))
        except Exception:
            return "error"
        plan = self._parse_artifact(artifact_content)
        applied_match = True
        not_applied_match = True
        for op in plan["create"]:
            t_path = self.state.repo_root / op["path"]
            if not t_path.is_file():
                applied_match = False
            else:
                if self._file_sha256(t_path) != self._str_sha256(op["content"]):
                    applied_match = False
            if t_path.is_file():
                not_applied_match = False
        for op in plan["delete"]:
            t_path = self.state.repo_root / op["path"]
            orig_hash = hmap.get(op["path"])
            if t_path.is_file():
                applied_match = False
                if self._file_sha256(t_path) != orig_hash:
                    not_applied_match = False
            else:
                b_path = self.backup_dir / op["path"]
                if not b_path.is_file() or self._file_sha256(b_path) != orig_hash:
                    not_applied_match = False
        for rel_p, orig_hash in hmap.items():
            if any(op["path"] == rel_p for op in plan["delete"]):
                continue
            t_path = self.state.repo_root / rel_p
            if not t_path.is_file():
                applied_match = False
                not_applied_match = False
                continue
            curr_hash = self._file_sha256(t_path)
            target_applied_content = None
            for op in plan["create"]:
                if op["path"] == rel_p:
                    target_applied_content = op["content"]
                    break
            if target_applied_content is not None:
                if curr_hash != self._str_sha256(target_applied_content):
                    applied_match = False
                if curr_hash != orig_hash:
                    not_applied_match = False
            else:
                if curr_hash != orig_hash:
                    applied_match = False
                    not_applied_match = False
        if applied_match:
            return "applied"
        if not_applied_match:
            return "not_applied"
        return "error"

    @staticmethod
    def copy_to_clipboard(text) -> int:
        lines_count = len(text.splitlines())
        payload = base64.b64encode(text.encode("utf-8")).decode("utf-8")
        sys.stdout.write(f"\033]52;c;{payload}\007")
        sys.stdout.flush()
        return lines_count

    @staticmethod
    def acquire_and_run(state_service: AppState, get_char_func):
        try:
            mgr = EnvironmentManager(state_service)
            mgr.run_loop(get_char_func)
            state_service.last_message = "Exited File Manager sub-loop."
        except Exception as e:
            state_service.last_message = f"❌ Sub-loop Engine Error: {e}"

    def run_loop(self, get_char_func):
        while True:
            os.system("clear" if os.name != "nt" else "cls")
            status = self._get_state()
            print(f"============================================================")
            print(f"📂 Batch Artifact File Manager")
            print(f"State:        {status.upper()}")
            print(f"============================================================")
            print("Commands Matrix:")
            print("   [q] Receive Refactor Artifact   [w] Toggle Execution (Apply/Undo)")
            print("   [e] Test Pipeline               [r] Resolve Mutation (Accept/Reject)")
            print("   [f] Back Out Immediately")
            print(f"============================================================")
            print("file-mgr> ", end="", flush=True)
            try:
                key = get_char_func().lower()
            except (KeyboardInterrupt, EOFError):
                break
            if key == "f":
                break
            if status == "error" and key in ("q", "w", "e", "r"):
                print("\n❌ System is in ERROR state. Action blocked. Clear blockages manually.")
                input("Press any key to return...")
                continue
            if key == "q":
                if status != "free":
                    print(f"\n❌ Refused: Pipeline state must be FREE (Current: {status}).")
                    input("Press any key to return...")
                    continue
                self.receive()
            elif key == "w":
                if status == "free":
                    print("\n❌ Refused: No artifact structured to toggle execution.")
                    input("Press any key to return...")
                    continue
                self.toggle_execution(status)
            elif key == "e":
                if status == "free":
                    print("\n❌ Refused: No testing state context available.")
                    input("Press any key to return...")
                    continue
                self.test_pipeline()
            elif key == "r":
                if status == "free":
                    print("\n❌ Refused: No ongoing mutation session available.")
                    input("Press any key to return...")
                    continue
                if self.resolve_mutation(status):
                    break

    def receive(self):
        print("\nEnter artifact stream payload (Ctrl+D to finish):")
        lines = []
        try:
            while True:
                lines.append(input())
        except EOFError:
            content = "\n".join(lines)
        except KeyboardInterrupt:
            print("\nAborted.")
            return
        plan = self._parse_artifact(content)
        if not plan["create"] and not plan["delete"]:
            print("\n❌ Validation Failed: No executable blocks matched structural format.")
            input("Press any key...")
            return
        hmap = {}
        for op in plan["create"]:
            t_path = self.state.repo_root / op["path"]
            if t_path.is_file():
                hmap[op["path"]] = self._file_sha256(t_path)
        for op in plan["delete"]:
            t_path = self.state.repo_root / op["path"]
            if not t_path.is_file():
                print(f"\n❌ Validation Failed: Targeted deletion file '{op['path']}' does not exist.")
                input("Press any key...")
                return
            hmap[op["path"]] = self._file_sha256(t_path)
        try:
            self.backup_dir.mkdir(parents=True, exist_ok=True)
            self.artifact_path.write_text(content, encoding="utf-8")
            self.hash_map_path.write_text(json.dumps(hmap, indent=4), encoding="utf-8")
            for rel_p in hmap.keys():
                src_f = self.state.repo_root / rel_p
                bak_f = self.backup_dir / rel_p
                bak_f.parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(src_f, bak_f)
            print("\n✔ Staged artifact completely. Hashed matching tracking matrices.")
            input("Press any key...")
        except Exception as e:
            if self.backup_dir.exists():
                shutil.rmtree(self.backup_dir)
            print(f"\n❌ Fatal Pipeline Staging Error: {e}")
            input("Press any key...")

    def toggle_execution(self, current_status: str):
        try:
            artifact_content = self.artifact_path.read_text(encoding="utf-8")
            hmap = json.loads(self.hash_map_path.read_text(encoding="utf-8"))
        except Exception as e:
            print(f"\n❌ Failed to load artifacts: {e}")
            input()
            return
        plan = self._parse_artifact(artifact_content)
        if current_status == "not_applied":
            for op in plan["create"]:
                t_path = self.state.repo_root / op["path"]
                if not t_path.is_file():
                    t_path.parent.mkdir(parents=True, exist_ok=True)
            for op in plan["create"]:
                t_path = self.state.repo_root / op["path"]
                with open(t_path, "w", encoding="utf-8") as f:
                    f.write(op["content"])
                os.chmod(t_path, 0o755)
            for op in plan["delete"]:
                t_path = self.state.repo_root / op["path"]
                if t_path.is_file():
                    os.remove(t_path)
                    self._cleanup_empty_dirs(t_path.parent)
            print("\n✔ Mutation state successfully APPLIED to workspace.")
            input("Press any key...")
        elif current_status == "applied":
            for op in plan["create"]:
                t_path = self.state.repo_root / op["path"]
                if op["path"] in hmap:
                    bak_f = self.backup_dir / op["path"]
                    shutil.copy2(bak_f, t_path)
                else:
                    if t_path.is_file():
                        os.remove(t_path)
                        self._cleanup_empty_dirs(t_path.parent)
            for op in plan["delete"]:
                t_path = self.state.repo_root / op["path"]
                bak_f = self.backup_dir / op["path"]
                t_path.parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(bak_f, t_path)
            print("\n✔ Mutation state successfully ROLLED BACK to safe baseline.")
            input("Press any key...")

    def _cleanup_empty_dirs(self, directory: Path):
        curr = directory
        while curr != self.state.repo_root:
            if curr.exists() and os.path.isdir(curr) and not os.listdir(curr):
                os.rmdir(curr)
                curr = curr.parent
            else:
                break

    def test_pipeline(self):
        print("\n[Executing Artifact Test Suite Pipeline]")
        print("test placeholder")
        input("\nPress any key to return...")

    def resolve_mutation(self, current_status: str) -> bool:
        if current_status == "applied":
            print(f"\n⚠️ WARNING: Safe backup tracking states will be permanently purged.")
            ans = input("Confirm structural ACCEPTANCE of ongoing changes? (y/n): ").strip().lower()
            if ans == 'y':
                self.past_dir.mkdir(parents=True, exist_ok=True)
                ts = int(time.time())
                dest_a = self.past_dir / f"artifact_{ts}.accepted"
                shutil.move(str(self.artifact_path), str(dest_a))
                shutil.rmtree(self.backup_dir)
                print("✔ Active mutation finalized into repository tree history completely.")
                input()
                return True
        elif current_status == "not_applied":
            print(f"\n⚠️ WARNING: Staged file matrices will be destroyed.")
            ans = input("Confirm dynamic REJECTION of staged structural modifications? (y/n): ").strip().lower()
            if ans == 'y':
                self.past_dir.mkdir(parents=True, exist_ok=True)
                ts = int(time.time())
                dest_a = self.past_dir / f"artifact_{ts}.rejected"
                shutil.move(str(self.artifact_path), str(dest_a))
                shutil.rmtree(self.backup_dir)
                print("✔ Changes rejected. Base configuration returned safely.")
                input()
                return True
        else:
            print("\n❌ Mutation must be dynamically APPLIED or completely UNAPPLIED to resolve explicitly.")
            input()
        return False

class DefaultPrompt:
    @staticmethod
    def get_default(fragment_name) -> str:
        mapping = {
            "game-runtime": DefaultPrompt.game_runtime,
            "client": DefaultPrompt.client,
            "consultant": DefaultPrompt.consultant,
            "domains": DefaultPrompt.domains,
            "interaction-protocol": DefaultPrompt.interaction_protocol,
        }
        method = mapping.get(fragment_name)
        return method() if method else None

    @staticmethod
    def game_runtime() -> str:
        return "=== src/pipelines/default/game-runtime.fragment ===\n--- START PROMPT ---\n<game-runtime>\n    §§client§§\n    §§consultant§§\n    §§domains§§\n    §§interaction-protocol§§\n    <init -> perform silent analysis, then reply in-role/>\n</game-runtime>.init()"

    @staticmethod
    def client() -> str:
        return "=== src/pipelines/default/client.fragment ===\n--- START PROMPT ---\n        <client>\n        </client>"

    @staticmethod
    def consultant() -> str:
        return "=== src/pipelines/default/consultant.fragment ===\n--- START PROMPT ---\n        <consultant>\ntruncated\n        </consultant>"

    @staticmethod
    def domains() -> str:
        return "=== src/pipelines/default/domains.fragment ===\n--- START PROMPT ---\n        </domains>truncated"

    @staticmethod
    def interaction_protocol() -> str:
        return "=== src/pipelines/default/interaction-protocol.fragment ===\n--- START PROMPT ---\n    <client-interaction-protocol>\ntruncated\n    </client-interaction-protocol>\n"

STATE = AppState()

if __name__ == "__main__":
    Harness(STATE).start()
